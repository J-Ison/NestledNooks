@page "/login"
@inject NavigationManager Navigation

<PageTitle>@SiteBranding.PageTitle("Sign in")</PageTitle>

<div class="guide-page auth-page">
    <header class="guide-hero guide-hero--auth">
        <div class="wrap guide-hero-inner">
            <p class="guide-hero-eyebrow">@SiteBranding.Name · @SiteBranding.RegionLine</p>
            <h1 class="guide-hero-title">Welcome back</h1>
            <p class="guide-hero-lead">Sign in to manage bookings, settings, and your Nestled Nooks account.</p>
        </div>
    </header>

    <main class="wrap guide-main auth-main">
        <article class="guide-card guide-card--auth">
            <header class="guide-card-header">
                <span class="guide-card-icon" aria-hidden="true">🔐</span>
                <div>
                    <h2 class="guide-card-title">Sign in</h2>
                    <p class="guide-card-subtitle">Use the email and password from your account</p>
                </div>
            </header>

            <div class="guide-card-body auth-card-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <p class="nn-note nn-note--error">@errorMessage</p>
                }

                <form method="post" action="/api/account/login" class="auth-form">
                    <div class="nn-form-group">
                        <label for="email">Email</label>
                        <input id="email"
                               name="email"
                               type="email"
                               class="nn-form-control"
                               placeholder="you@email.com"
                               required />
                    </div>

                    <div class="nn-form-group">
                        <label for="password">Password</label>
                        <input id="password"
                               name="password"
                               type="password"
                               class="nn-form-control"
                               placeholder="Enter your password"
                               required />
                    </div>

                    <button type="submit" class="nn-btn-primary">Sign in</button>
                </form>

                <p class="auth-switch">
                    New here? <a class="guide-link" href="/register">Create an account</a>
                </p>
            </div>
        </article>

        <footer class="guide-footer">
            <a class="guide-footer-btn guide-footer-btn--secondary" href="/">← Deerfield Retreat</a>
            <a class="guide-footer-btn guide-footer-btn--primary" href="/booking?property=deerfield-retreat">Request booking</a>
        </footer>
    </main>
</div>

@code {
    private string errorMessage = string.Empty;

    protected override void OnInitialized()
    {
        var uri = new Uri(Navigation.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("error", out var error))
        {
            if (error == "UserNotFound")
                errorMessage = "User not found.";
            else if (error == "InvalidLogin")
                errorMessage = "Invalid email or password.";
            else if (error == "ServerError")
                errorMessage = "Sign-in is temporarily unavailable. Please try again in a minute or contact support if this continues.";
        }
    }
}
