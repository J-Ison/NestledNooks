@page "/booking"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using MudBlazor
@using NestledNooks.Data
@using NestledNooks.Models
@using NestledNooks.Services

@inject NavigationManager Navigation
@inject IBookingRequestService BookingService
@inject IBookingAvailabilityService AvailabilityService
@inject BookingPricingService PricingService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Book your stay · Nestled Nooks</PageTitle>
<HeadContent>
    <meta name="description" content="Request a reservation at Nestled Nooks. Only available dates can be selected — synced with Airbnb and Vrbo." />
</HeadContent>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-4">
    <MudText Typo="Typo.h4" Class="mb-2">Request a stay</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Choose available dates below. Pending requests hold dates until we approve or decline.
        @if (_property is not null)
        {
            <span> Minimum @_property.MinimumNights nights.</span>
        }
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Class="mb-4" />
    }
    else
    {
        <MudAlert Severity="Severity.Info" Class="mb-4" Dense="true">
            Calendar blocks include Airbnb/Vrbo bookings (when iCal URLs are configured) and pending site requests.
        </MudAlert>

        <MudCard Class="mb-4">
            <MudCardContent>
                <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
                    <DataAnnotationsValidator />

                    <MudSelect T="string" @bind-Value="_model.PropertySlug"
                               Label="Property"
                               Variant="Variant.Outlined"
                               Class="mb-3"
                               Disabled="_submitting">
                        @foreach (var p in _properties)
                        {
                            <MudSelectItem Value="@p.Slug">@p.DisplayName</MudSelectItem>
                        }
                    </MudSelect>

                    <MudTextField @bind-Value="_model.GuestFullName"
                                  For="@(() => _model.GuestFullName)"
                                  Label="Full name"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  Disabled="_submitting" />

                    <MudTextField @bind-Value="_model.GuestEmail"
                                  For="@(() => _model.GuestEmail)"
                                  Label="Email"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  InputType="InputType.Email"
                                  Disabled="_submitting" />

                    <MudTextField @bind-Value="_model.GuestPhone"
                                  For="@(() => _model.GuestPhone)"
                                  Label="Phone"
                                  Variant="Variant.Outlined"
                                  Class="mb-3"
                                  Disabled="_submitting" />

                    <MudText Typo="Typo.subtitle2" Class="mb-2">Dates</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3">
                        Grayed-out days are already booked. Select check-in, then check-out.
                    </MudText>
                    <MudGrid Class="mb-3">
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-2" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.caption" Class="mb-2 px-2">Check-in</MudText>
                                <MudDatePicker @bind-Date="_checkInDate"
                                               @bind-Date:after="OnDatesUpdated"
                                               PickerVariant="PickerVariant.Static"
                                               MinDate="_minSelectable"
                                               MaxDate="_maxSelectable"
                                               DateDisabledFunc="IsDateUnavailable"
                                               Disabled="_submitting"
                                               ShowToolbar="false" />
                            </MudPaper>
                        </MudItem>
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-2" Elevation="0" Outlined="true">
                                <MudText Typo="Typo.caption" Class="mb-2 px-2">Check-out</MudText>
                                <MudDatePicker @bind-Date="_checkOutDate"
                                               @bind-Date:after="OnDatesUpdated"
                                               PickerVariant="PickerVariant.Static"
                                               MinDate="_checkOutMinDate"
                                               MaxDate="_maxSelectable"
                                               DateDisabledFunc="IsDateUnavailable"
                                               Disabled="_submitting"
                                               ShowToolbar="false" />
                            </MudPaper>
                        </MudItem>
                    </MudGrid>

                    <MudNumericField @bind-Value="_model.GuestCount"
                                     For="@(() => _model.GuestCount)"
                                     Label="Guests"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Max="@(_property?.MaxGuests ?? 12)"
                                     Class="mb-3"
                                     Disabled="_submitting" />

                    <MudNumericField @bind-Value="_model.PetCount"
                                     For="@(() => _model.PetCount)"
                                     Label="Pets"
                                     Variant="Variant.Outlined"
                                     Min="0"
                                     Max="@(_property?.MaxPets ?? 4)"
                                     Class="mb-3"
                                     Disabled="_submitting" />

                    <MudTextField @bind-Value="_model.Notes"
                                  For="@(() => _model.Notes)"
                                  Label="Special requests (optional)"
                                  Variant="Variant.Outlined"
                                  Lines="4"
                                  Class="mb-3"
                                  Disabled="_submitting" />

                    <MudAlert Severity="Severity.Info" Class="mb-3" Dense="true">
                        We will confirm your total rate after we review your request (dynamic pricing applies).
                    </MudAlert>

                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                    }

                    @if (!string.IsNullOrEmpty(_success))
                    {
                        <MudAlert Severity="Severity.Success" Class="mb-3">@_success</MudAlert>
                    }

                    <MudButton ButtonType="ButtonType.Submit"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="_submitting">
                        @(_submitting ? "Submitting…" : "Request booking")
                    </MudButton>
                </EditForm>
            </MudCardContent>
        </MudCard>
    }
</MudContainer>

@code {
    private readonly BookingFormModel _model = new();
    private List<PropertyBookingOptions> _properties = [];
    private PropertyBookingOptions? _property;
    private HashSet<DateOnly> _unavailableDates = [];

    private DateTime? _checkInDate;
    private DateTime? _checkOutDate;
    private DateTime _minSelectable = DateTime.Today;
    private DateTime _maxSelectable = DateTime.Today.AddMonths(18);

    private DateTime _checkOutMinDate => _checkInDate?.Date.AddDays(1) ?? _minSelectable;

    private bool _loading = true;
    private bool _submitting;
    private string? _error;
    private string? _success;
    private string? _userId;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = UserManager.GetUserId(auth.User);

        var user = _userId is not null
            ? await UserManager.GetUserAsync(auth.User)
            : null;

        if (user is not null)
        {
            _model.GuestFullName = user.UserName ?? "";
            _model.GuestEmail = user.Email ?? "";
            _model.GuestPhone = user.PhoneNumber;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("property", out var slug) && !string.IsNullOrWhiteSpace(slug))
            _model.PropertySlug = slug.ToString();

        _properties = PricingService.GetAllProperties().ToList();
        if (_properties.Count == 0)
            _model.PropertySlug = BookingFormModel.DeerfieldSlug;

        _property = PricingService.GetProperty(_model.PropertySlug)
            ?? _properties.FirstOrDefault();
        if (_property is not null)
            _model.PropertySlug = _property.Slug;

        try
        {
            await AvailabilityService.SyncExternalCalendarsAsync();
        }
        catch
        {
            // Continue with local holds only
        }

        await RefreshUnavailableDatesAsync();
        _loading = false;
    }

    private async Task RefreshUnavailableDatesAsync()
    {
        var from = DateOnly.FromDateTime(_minSelectable);
        var to = DateOnly.FromDateTime(_maxSelectable);
        var list = await AvailabilityService.GetUnavailableDatesAsync(_model.PropertySlug, from, to);
        _unavailableDates = list.ToHashSet();
    }

    private bool IsDateUnavailable(DateTime date) =>
        _unavailableDates.Contains(DateOnly.FromDateTime(date.Date));

    private void OnDatesUpdated()
    {
        _model.CheckIn = _checkInDate.HasValue ? DateOnly.FromDateTime(_checkInDate.Value.Date) : null;
        _model.CheckOut = _checkOutDate.HasValue ? DateOnly.FromDateTime(_checkOutDate.Value.Date) : null;

        if (_model.CheckIn is { } ci && _model.CheckOut is { } co && co <= ci)
            _checkOutDate = null;
    }

    private async Task SubmitAsync()
    {
        _model.CheckIn = _checkInDate.HasValue ? DateOnly.FromDateTime(_checkInDate.Value) : null;
        _model.CheckOut = _checkOutDate.HasValue ? DateOnly.FromDateTime(_checkOutDate.Value) : null;

        _submitting = true;
        _error = null;
        _success = null;

        try
        {
            var result = await BookingService.SubmitAsync(_model, _userId);
            if (!result.Succeeded)
            {
                _error = result.ErrorMessage ?? "Could not submit request.";
                return;
            }

            _success = string.IsNullOrEmpty(result.EmailWarning)
                ? $"Booking request {result.BookingNumber} was saved. " +
                  "We emailed you a confirmation and will notify you when your stay is approved or declined."
                : $"Booking request {result.BookingNumber} was saved. {result.EmailWarning}";
            await RefreshUnavailableDatesAsync();
        }
        catch (Exception ex)
        {
            _error = $"Could not submit: {ex.Message}";
        }
        finally
        {
            _submitting = false;
        }
    }
}
