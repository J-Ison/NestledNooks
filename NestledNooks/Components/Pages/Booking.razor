@page "/booking"
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using MudBlazor
@using NestledNooks.Data
@using NestledNooks.Models
@using NestledNooks.Services

@inject NavigationManager Navigation
@inject IBookingRequestService BookingService
@inject IBookingAvailabilityService AvailabilityService
@inject BookingPricingService PricingService
@inject ISiteSettingsService SiteSettingsService
@inject IPropertyService PropertyService
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IBookingIntegrationStatusService IntegrationStatusService
@inject ILogger<Booking> Logger

<PageTitle>@SiteBranding.PageTitle("Request booking")</PageTitle>
<HeadContent>
    <meta name="description" content="Request a reservation at Deerfield Retreat. Choose available dates and submit a direct booking request." />
</HeadContent>

<div class="guide-page">
    <header class="guide-hero guide-hero--booking">
        <div class="wrap guide-hero-inner">
            <p class="guide-hero-eyebrow">Deerfield Retreat · @SiteBranding.RegionLine</p>
            <h1 class="guide-hero-title">Request a stay</h1>
            <p class="guide-hero-lead">
                Choose available dates below. Pending requests hold dates until we approve or decline.
                @if (_listingSettings is not null)
                {
                    <span> Minimum @_listingSettings.MinimumNights nights.</span>
                    <span> Book @_listingSettings.MinAdvanceBookingDays–@_listingSettings.EffectiveMaxBookingDaysAhead days ahead.</span>
                }
            </p>
        </div>
    </header>

    <main class="wrap guide-main">
        @if (_loading)
        {
            <p class="nn-loading">Loading availability…</p>
        }
        else
        {
            <article class="guide-card guide-card--booking">
                <header class="guide-card-header">
                    <span class="guide-card-icon" aria-hidden="true">📅</span>
                    <div>
                        <h2 class="guide-card-title">Booking request</h2>
                        <p class="guide-card-subtitle">Submit your stay dates and details</p>
                    </div>
                </header>

                <div class="guide-card-body nn-booking-mud">
                    @if (!_directBookingsEnabled && !_isOwner)
                    {
                        <p class="nn-note nn-note--warn">
                            Direct booking is temporarily unavailable while we finish setup.
                            Please <a class="mgmt-link" href="/contact">contact us</a> if you need help planning a stay.
                        </p>
                    }
                    else
                    {
                        @if (!_directBookingsEnabled && _isOwner)
                        {
                            <p class="nn-note nn-note--warn">
                                <strong>Owner test mode.</strong> Public booking is turned off — only your Owner account can submit requests right now.
                                Turn bookings back on under <a class="mgmt-link" href="/account/manage/site">Manage site</a>.
                            </p>
                        }

                    @if (_isHostStaff && _integrationStatus is not null)
                    {
                        <div class="nn-booking-integration-panel" aria-label="Integration sync status (staff only)">
                            <p class="nn-booking-section-title">Integration sync (staff)</p>
                            <p class="nn-booking-section-hint">Rates sync on a schedule; calendar refresh runs on this page load.</p>
                            <ul class="nn-booking-integration-list">
                                @foreach (var channel in new[] { _integrationStatus.Airbnb, _integrationStatus.Vrbo, _integrationStatus.PriceLabs })
                                {
                                    <li class="nn-booking-integration-item @GetIntegrationClass(channel)">
                                        <span class="nn-booking-integration-name">@channel.Name</span>
                                        <span class="nn-booking-integration-state">@GetIntegrationLabel(channel)</span>
                                        <span class="nn-booking-integration-detail">@channel.Detail</span>
                                        @if (channel.LastSyncedAtUtc is { } synced)
                                        {
                                            <span class="nn-booking-integration-time">Last sync @synced.ToLocalTime().ToString("g")</span>
                                        }
                                    </li>
                                }
                            </ul>
                        </div>
                    }

                    <p class="nn-note">
                        Unavailable dates are grayed out. Pending requests hold dates until we approve or decline.
                    </p>

                    <EditForm Model="@_model" OnValidSubmit="SubmitAsync">
                        <DataAnnotationsValidator />

                        @if (_properties.Count > 1)
                        {
                            <MudSelect T="string" @bind-Value="_model.PropertySlug"
                                       @bind-Value:after="OnPropertyChangedAsync"
                                       Label="Property"
                                       Variant="Variant.Outlined"
                                       Class="mb-3"
                                       Disabled="_submitting">
                                @foreach (var p in _properties)
                                {
                                    <MudSelectItem Value="@p.Slug">@p.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        else if (_property is not null)
                        {
                            <p class="nn-property-label">Property: @_property.DisplayName</p>
                        }

                        <MudTextField @bind-Value="_model.GuestFullName"
                                      For="@(() => _model.GuestFullName)"
                                      Label="Full name"
                                      Variant="Variant.Outlined"
                                      Class="mb-3"
                                      Disabled="_submitting" />

                        <MudTextField @bind-Value="_model.GuestEmail"
                                      For="@(() => _model.GuestEmail)"
                                      Label="Email"
                                      Variant="Variant.Outlined"
                                      Class="mb-3"
                                      InputType="InputType.Email"
                                      Disabled="_submitting" />

                        <MudTextField @bind-Value="_model.GuestPhone"
                                      For="@(() => _model.GuestPhone)"
                                      Label="Phone"
                                      Variant="Variant.Outlined"
                                      Class="mb-3"
                                      Disabled="_submitting" />

                        <p class="nn-booking-section-title">Dates</p>
                        <p class="nn-booking-section-hint">
                            Tap your check-in, then your check-out on the same calendar.
                            Check-in from @_minSelectable.ToString("MMM d, yyyy") through @_maxCheckIn.ToString("MMM d, yyyy").
                            Grayed-out nights are booked or held. Ranges cannot cross gray dates.
                        </p>

                        <div class="nn-booking-dates nn-booking-dates--range">
                            @if (_dateRange?.Start is DateTime start && _dateRange.End is DateTime end)
                            {
                                <p class="nn-booking-range-summary">
                                    @start.ToString("MMM d, yyyy") → @end.ToString("MMM d, yyyy")
                                    · @((end.Date - start.Date).Days) night@((end.Date - start.Date).Days == 1 ? "" : "s")
                                </p>
                            }
                            else if (_dateRange?.Start is DateTime checkInOnly)
                            {
                                <p class="nn-booking-range-summary">Check-in @checkInOnly.ToString("MMM d, yyyy") — now choose check-out</p>
                            }

                            <MudDateRangePicker @bind-DateRange="_dateRange"
                                                @bind-DateRange:after="OnDateRangeUpdatedAsync"
                                                PickerVariant="PickerVariant.Static"
                                                MinDate="_minSelectable"
                                                MaxDate="_maxCheckOut"
                                                IsDateDisabledFunc="@IsDateUnavailable"
                                                AdditionalDateClassesFunc="@GetUnavailableDateClass"
                                                Disabled="_submitting"
                                                ShowToolbar="false"
                                                Class="nn-booking-range-picker" />
                        </div>

                        @if (_model.CheckIn is { } farCheckIn && _listingSettings is not null && _listingSettings.IsBeyondExternalCalendarTrust(farCheckIn))
                        {
                            <p class="nn-note">
                                @if (_showChannelPriceLinks)
                                {
                                    <text>This stay is more than @_listingSettings.ExternalCalendarTrustDays days out — Airbnb doesn't show availability that far ahead.
                                    You can still submit a request; we'll confirm the dates before approving.</text>
                                }
                                else
                                {
                                    <text>This stay is more than @_listingSettings.ExternalCalendarTrustDays days out — synced calendars may not show availability that far ahead.
                                    You can still submit a request; we'll confirm the dates before approving.</text>
                                }
                                <a class="mgmt-link" href="/contact">Contact us</a> if you prefer to talk first.
                            </p>
                        }

                        <MudNumericField @bind-Value="_model.GuestCount"
                                         For="@(() => _model.GuestCount)"
                                         Label="Guests"
                                         Variant="Variant.Outlined"
                                         Min="1"
                                         Max="@(_property?.MaxGuests ?? 12)"
                                         Class="mb-3"
                                         Disabled="_submitting" />

                        <MudNumericField T="int"
                                         Value="_model.PetCount"
                                         ValueChanged="OnPetCountChangedAsync"
                                         For="@(() => _model.PetCount)"
                                         Label="Pets"
                                         Variant="Variant.Outlined"
                                         Min="0"
                                         Max="@(_property?.MaxPets ?? 4)"
                                         Class="mb-3"
                                         Disabled="_submitting" />
                        @if (_listingSettings is { PetDepositPerTwoPets: > 0 })
                        {
                            <p class="nn-booking-section-hint mb-3">
                                Pet deposit @MoneyFormat.Usd(_listingSettings.PetDepositPerTwoPets) per 2 pets (rounded up).
                            </p>
                        }

                        <MudTextField @bind-Value="_model.Notes"
                                      For="@(() => _model.Notes)"
                                      Label="Special requests (optional)"
                                      Variant="Variant.Outlined"
                                      Lines="4"
                                      Class="mb-3"
                                      Disabled="_submitting" />

                        @if (_quoteLoading && _quote is null)
                        {
                            <p class="nn-note">Calculating estimate…</p>
                        }
                        else if (_quote is not null)
                        {
                            <div class="nn-booking-quote @(_quoteLoading ? "nn-booking-quote--updating" : null)">
                                <div class="nn-booking-quote-head">
                                    <p class="nn-booking-section-title">Estimated total</p>
                                    <DiscountedTotalDisplay Quote="_quote" CssClass="nn-discounted-total--booking" />
                                </div>
                                <ul class="nn-booking-quote-lines">
                                    <li>@_quote.Nights night@(_quote.Nights == 1 ? "" : "s") · lodging @MoneyFormat.Usd(_quote.Subtotal + _quote.DiscountAmount)</li>
                                    @if (_quote.HasDiscount)
                                    {
                                        <li class="nn-booking-quote-discount">@_quote.DiscountLabel −@MoneyFormat.Usd(_quote.DiscountAmount)</li>
                                    }
                                    @if (_quote.CleaningFee > 0)
                                    {
                                        <li>Cleaning fee @MoneyFormat.Usd(_quote.CleaningFee)</li>
                                    }
                                    @if (_quote.PetFee > 0)
                                    {
                                        <li>Pet deposit @MoneyFormat.Usd(_quote.PetFee)</li>
                                    }
                                    <li><strong>Total @MoneyFormat.Usd(_quote.TotalAmount)</strong></li>
                                </ul>
                                @if (_quoteLoading)
                                {
                                    <p class="nn-booking-section-hint">Updating estimate…</p>
                                }
                                @if (_isHostStaff)
                                {
                                    @if (_quote.UsesDynamicPricing)
                                    {
                                        <p class="nn-booking-section-hint">Staff: rates from PriceLabs (@MoneyFormat.Usd(_quote.NightlyRate) avg/night).</p>
                                    }
                                    else
                                    {
                                        <p class="nn-booking-section-hint">Staff: using site base rate (PriceLabs not synced).</p>
                                    }
                                }
                            </div>
                        }
                        else if (_model.CheckIn is not null && _model.CheckOut is not null)
                        {
                            <p class="nn-note nn-note--error">@(_quoteError ?? "Could not calculate an estimate for those dates.")</p>
                        }

                        <p class="nn-note">
                            Final total is confirmed when we approve your request. Payment will be collected after approval.
                        </p>

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <div class="nn-note nn-note--error" role="alert">
                                <p>@_error</p>
                                @if (!string.IsNullOrEmpty(_errorCode))
                                {
                                    <p class="nn-booking-error-ref"><strong>Ref: @_errorCode</strong></p>
                                }
                            </div>
                        }

                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Class="nn-booking-submit"
                                   Disabled="_submitting">
                            @(_submitting ? "Submitting…" : "Request booking")
                        </MudButton>
                    </EditForm>
                    }
                </div>
            </article>

            <footer class="guide-footer">
                <a class="guide-footer-btn guide-footer-btn--secondary" href="/properties/deerfield-retreat">← Deerfield Retreat</a>
                <a class="guide-footer-btn guide-footer-btn--primary" href="/properties/deerfield-retreat/guide">Guest guide</a>
            </footer>
        }
    </main>
</div>

@code {
    private readonly BookingFormModel _model = new();
    private List<PropertyBookingOptions> _properties = [];
    private PropertyBookingOptions? _property;
    private HashSet<DateOnly> _unavailableDates = [];

    private DateRange? _dateRange;
    private DateTime _minSelectable = DateTime.Today;
    private DateTime _maxCheckIn = DateTime.Today.AddDays(365);
    private DateTime _maxCheckOut = DateTime.Today.AddDays(395);
    private PropertyListingSettings? _listingSettings;

    private bool _loading = true;
    private bool _submitting;
    private bool _quoteLoading;
    private readonly SemaphoreSlim _quoteRefreshGate = new(1, 1);
    private int _quoteRefreshVersion;
    private string? _error;
    private string? _errorCode;
    private string? _quoteError;
    private BookingQuote? _quote;
    private string? _userId;
    private bool _directBookingsEnabled = true;
    private bool _isOwner;
    private bool _isHostStaff;
    private bool _showChannelPriceLinks = true;
    private BookingIntegrationStatusSnapshot? _integrationStatus;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        _userId = UserManager.GetUserId(auth.User);
        _isOwner = HostStaffAuthorization.IsOwner(auth.User);
        _isHostStaff = HostStaffAuthorization.IsHostStaff(auth.User);

        var siteSettings = await SiteSettingsService.GetAsync();
        _directBookingsEnabled = siteSettings.DirectBookingsEnabled;

        var user = _userId is not null
            ? await UserManager.GetUserAsync(auth.User)
            : null;

        if (user is not null)
        {
            _model.GuestFullName = user.UserName ?? "";
            _model.GuestEmail = user.Email ?? "";
            _model.GuestPhone = user.PhoneNumber;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("property", out var slug) && !string.IsNullOrWhiteSpace(slug))
            _model.PropertySlug = slug.ToString();

        if (query.TryGetValue("checkIn", out var checkInRaw) &&
            DateOnly.TryParse(checkInRaw.ToString(), out var parsedCheckIn))
        {
            _model.CheckIn = parsedCheckIn;
        }

        if (query.TryGetValue("checkOut", out var checkOutRaw) &&
            DateOnly.TryParse(checkOutRaw.ToString(), out var parsedCheckOut))
        {
            _model.CheckOut = parsedCheckOut;
        }

        if (query.TryGetValue("pets", out var petsRaw) &&
            int.TryParse(petsRaw.ToString(), out var pets) &&
            pets >= 0)
        {
            _model.PetCount = pets;
        }

        if (_model.CheckIn is { } ci && _model.CheckOut is { } co && co > ci)
        {
            _dateRange = new DateRange(ci.ToDateTime(TimeOnly.MinValue), co.ToDateTime(TimeOnly.MinValue));
        }

        _properties = PricingService.GetAllProperties().ToList();
        if (_properties.Count == 0)
            _model.PropertySlug = BookingFormModel.DeerfieldSlug;

        _property = PricingService.GetProperty(_model.PropertySlug)
            ?? _properties.FirstOrDefault();
        if (_property is not null)
            _model.PropertySlug = _property.Slug;

        var rentalProperty = await PropertyService.GetBySlugAsync(_model.PropertySlug);
        _showChannelPriceLinks = rentalProperty?.ShowChannelPriceLinks ?? true;

        SyncModelDatesFromRange();

        await ApplyListingSettingsAsync();

        try
        {
            await AvailabilityService.SyncExternalCalendarsAsync();
        }
        catch
        {
            // Continue with local holds only
        }

        await RefreshUnavailableDatesAsync();

        if (_isHostStaff)
            _integrationStatus = await IntegrationStatusService.GetSnapshotAsync(_model.PropertySlug);

        if (_model.CheckIn is not null && _model.CheckOut is not null)
            await RefreshQuoteAsync();

        _loading = false;
    }

    private static string GetIntegrationClass(IntegrationChannelSnapshot channel)
    {
        if (!channel.IsConfigured)
            return "nn-booking-integration-item--off";

        return channel.IsSynced
            ? "nn-booking-integration-item--ok"
            : "nn-booking-integration-item--warn";
    }

    private static string GetIntegrationLabel(IntegrationChannelSnapshot channel)
    {
        if (!channel.IsConfigured)
            return "Not configured";

        return channel.IsSynced ? "Synced" : "Not synced";
    }

    private async Task OnPropertyChangedAsync()
    {
        _property = PricingService.GetProperty(_model.PropertySlug);
        _dateRange = null;
        _model.CheckIn = null;
        _model.CheckOut = null;
        _quote = null;
        await ApplyListingSettingsAsync();
        await RefreshUnavailableDatesAsync();
        if (_isHostStaff)
            _integrationStatus = await IntegrationStatusService.GetSnapshotAsync(_model.PropertySlug);
    }

    private async Task ApplyListingSettingsAsync()
    {
        _listingSettings = await PropertyService.GetListingSettingsAsync(_model.PropertySlug);
        var today = DateTime.Today;
        _minSelectable = today.AddDays(_listingSettings.MinAdvanceBookingDays);
        _maxCheckIn = today.AddDays(_listingSettings.EffectiveMaxBookingDaysAhead);
        _maxCheckOut = today.AddDays(_listingSettings.EffectiveMaxBookingDaysAhead + 30);
    }

    private async Task RefreshUnavailableDatesAsync()
    {
        var from = DateOnly.FromDateTime(_minSelectable);
        var to = DateOnly.FromDateTime(_maxCheckOut);
        var list = await AvailabilityService.GetUnavailableDatesAsync(_model.PropertySlug, from, to);
        _unavailableDates = list.ToHashSet();
    }

    private bool IsDateUnavailable(DateTime date) =>
        _unavailableDates.Contains(DateOnly.FromDateTime(date.Date));

    private string GetUnavailableDateClass(DateTime date) =>
        IsDateUnavailable(date) ? "nn-booking-date-blocked" : "";

    private async Task OnDateRangeUpdatedAsync()
    {
        SyncModelDatesFromRange();

        if (_model.CheckIn is { } ci && _model.CheckOut is { } co && co <= ci)
        {
            _dateRange = new DateRange(_dateRange?.Start, null);
            _model.CheckOut = null;
        }

        await RefreshQuoteAsync();
    }

    private void SyncModelDatesFromRange()
    {
        if (_dateRange?.Start is DateTime start)
            _model.CheckIn = DateOnly.FromDateTime(start.Date);
        else
            _model.CheckIn = null;

        if (_dateRange?.End is DateTime end)
            _model.CheckOut = DateOnly.FromDateTime(end.Date);
        else
            _model.CheckOut = null;
    }

    private async Task RefreshQuoteAsync(bool skipAvailabilityCheck = false, bool preserveExistingQuote = false)
    {
        var version = Interlocked.Increment(ref _quoteRefreshVersion);
        _quoteError = null;

        if (!preserveExistingQuote)
            _quote = null;

        if (_model.CheckIn is not { } checkIn || _model.CheckOut is not { } checkOut || checkOut <= checkIn)
        {
            _quote = null;
            _quoteLoading = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await _quoteRefreshGate.WaitAsync();
        try
        {
            if (version != _quoteRefreshVersion)
                return;

            _quoteLoading = true;
            await InvokeAsync(StateHasChanged);

            try
            {
                if (!skipAvailabilityCheck)
                {
                    if (!await AvailabilityService.IsRangeAvailableAsync(
                            _model.PropertySlug,
                            checkIn,
                            checkOut))
                    {
                        _quoteError = "Those dates overlap an existing reservation or hold. Please choose a different range.";
                        if (!preserveExistingQuote)
                            _quote = null;
                        return;
                    }
                }

                if (version != _quoteRefreshVersion)
                    return;

                _quote = await PricingService.CalculateAsync(
                    _model.PropertySlug,
                    checkIn,
                    checkOut,
                    _model.PetCount);
            }
            catch (InvalidOperationException ex)
            {
                _quoteError = ex.Message;
                if (!preserveExistingQuote)
                    _quote = null;
            }
            catch (Exception)
            {
                _quoteError = "Could not calculate an estimate for those dates.";
                if (!preserveExistingQuote)
                    _quote = null;
            }
        }
        finally
        {
            if (version == _quoteRefreshVersion)
                _quoteLoading = false;

            _quoteRefreshGate.Release();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnPetCountChangedAsync(int value)
    {
        if (_model.PetCount == value)
            return;

        _model.PetCount = value;
        await Task.Yield();
        await RefreshQuoteAsync(skipAvailabilityCheck: true, preserveExistingQuote: true);
    }

    private async Task SubmitAsync()
    {
        SyncModelDatesFromRange();

        _submitting = true;
        _error = null;
        _errorCode = null;

        try
        {
            var result = await BookingService.SubmitAsync(_model, _userId);
            if (!result.Succeeded)
            {
                _errorCode = result.ErrorCode;
                _error = result.ErrorMessage ?? "Could not submit request.";
                return;
            }

            var query = new Dictionary<string, object?>
            {
                ["ref"] = result.BookingNumber!,
            };

            if (!string.IsNullOrEmpty(result.EmailWarning))
                query["emailWarning"] = "1";

            var confirmationUrl = Navigation.GetUriWithQueryParameters("/booking/confirmation", query);
            Navigation.NavigateTo(confirmationUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorCode = BookingSubmitErrorCodes.Unexpected;
            _error = "Could not submit your request. Please try again or contact us.";
            Logger.LogError(ex, "Booking submit failed ({ErrorCode}).", BookingSubmitErrorCodes.Unexpected);
        }
        finally
        {
            _submitting = false;
        }
    }
}
