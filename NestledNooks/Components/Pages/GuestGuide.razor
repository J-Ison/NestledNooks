@page "/properties/deerfield-retreat/guide"
@rendermode InteractiveServer

<PageTitle>@SiteBranding.PageTitle("Guest guide — Deerfield Retreat")</PageTitle>
<HeadContent>
    <meta name="description" content="House information, local recommendations, and helpful resources for guests staying at Deerfield Retreat in the Black Hills near Rapid City." />
</HeadContent>

<div class="guide-page">
    <header class="guide-hero">
        <div class="wrap guide-hero-inner">
            <p class="guide-hero-eyebrow">Deerfield Retreat · @SiteBranding.RegionLine</p>
            <h1 class="guide-hero-title">Guest guide</h1>
            <p class="guide-hero-lead">
                House details, local favorites, and stay resources — all in one place.
                Wi‑Fi and access codes are in your confirmation email.
            </p>
        </div>
    </header>

    <main class="wrap guide-main">
        <nav class="guide-nav" aria-label="Guide sections">
            <a class="guide-nav-pill guide-nav-pill--house" href="#house">House info</a>
            <a class="guide-nav-pill guide-nav-pill--local" href="#local">Local picks</a>
            <a class="guide-nav-pill guide-nav-pill--resources" href="#resources">Resources</a>
            <a class="guide-nav-pill guide-nav-pill--neutral" href="/contact">Contact</a>
        </nav>

        <article id="house" class="guide-card guide-card--house">
            <header class="guide-card-header">
                <span class="guide-card-icon" aria-hidden="true">🏠</span>
                <div>
                    <h2 class="guide-card-title">House information</h2>
                    <p class="guide-card-subtitle">Arrival, during your stay, and checkout</p>
                </div>
            </header>
            <div class="guide-card-body">
                <p class="guide-intro">
                    Deerfield Retreat is a full home near Rapid City. Check your booking confirmation email for
                    Wi‑Fi, door codes, and any arrival notes specific to your stay.
                </p>
                <ul class="guide-list">
                    <li><strong>Check-in:</strong> 4:00 PM · <strong>Check-out:</strong> 10:00 AM (unless we agree otherwise)</li>
                    <li><strong>Parking:</strong> Use the driveway and designated guest parking — no blocking neighbors or the road</li>
                    <li><strong>Quiet hours:</strong> 10:00 PM – 8:00 AM — respect neighbors and wildlife</li>
                    <li><strong>Thermostat:</strong> Please don’t set below 65°F in winter or below 72°F cooling in summer when away</li>
                    <li><strong>Kitchen:</strong> Full appliances, dishes, and basics — please run the dishwasher before checkout if you used it</li>
                    <li><strong>Washer &amp; dryer:</strong> Available for longer stays — detergent is usually under the sink or in the laundry area</li>
                    <li><strong>BBQ &amp; fire pit:</strong> Outdoor use only when conditions are safe — fully extinguish before turning in</li>
                    <li><strong>Trash:</strong> Bag trash in the kitchen; take bags to the outdoor bins. Recycle when possible</li>
                    <li><strong>Pets:</strong> Only with prior approval — clean up after pets and keep them off furniture unless covered</li>
                </ul>

                <div class="guide-subblock">
                    <h3 class="guide-subblock-title">Before you leave</h3>
                    <ul class="guide-list">
                        <li>Strip used beds and leave linens in a pile (or as noted in your email)</li>
                        <li>Load and start the dishwasher, or wash and put away dishes</li>
                        <li>Take trash to outdoor bins</li>
                        <li>Turn off lights, lock doors, and close windows</li>
                        <li>Report anything broken or missing so we can fix it for the next guest</li>
                    </ul>
                </div>
            </div>
        </article>

        <article id="local" class="guide-card guide-card--local">
            <header class="guide-card-header">
                <span class="guide-card-icon" aria-hidden="true">⛰️</span>
                <div>
                    <h2 class="guide-card-title">Local recommendations</h2>
                    <p class="guide-card-subtitle">Groceries, dining, and Black Hills highlights</p>
                </div>
            </header>
            <div class="guide-card-body">
                <p class="guide-intro">
                    Rapid City and the Black Hills are about 20 minutes away. Distances vary with traffic and season —
                    always check hours before you go.
                </p>

                <div class="guide-subblock">
                    <h3 class="guide-subblock-title">Groceries &amp; essentials</h3>
                    <ul class="guide-list">
                        <li><strong>Rapid City:</strong> Walmart, Target, Costco, and natural-food options along I-90 / Highway 16</li>
                        <li><strong>Smaller towns nearby:</strong> Quick stops for milk, ice, and basics — stock up if you’re arriving late</li>
                    </ul>
                </div>

                <div class="guide-subblock">
                    <h3 class="guide-subblock-title">Food &amp; coffee</h3>
                    <ul class="guide-list">
                        <li><strong>Downtown Rapid City:</strong> Restaurants, breweries, and summer events on Main Street</li>
                        <li><strong>Family-friendly:</strong> Pizza, burgers, and casual sit-down spots throughout Rapid — search maps for what’s open</li>
                        <li><strong>Coffee:</strong> Several local roasters and cafés in Rapid; grab to-go before a long drive to the monuments</li>
                    </ul>
                </div>

                <div class="guide-subblock">
                    <h3 class="guide-subblock-title">Must-see Black Hills</h3>
                    <ul class="guide-list">
                        <li><strong>Mount Rushmore</strong> — iconic; go early or late in peak season</li>
                        <li><strong>Crazy Horse Memorial</strong> — ongoing monument; cultural center and museum</li>
                        <li><strong>Custer State Park</strong> — wildlife loop, Sylvan Lake, hiking, and Needles Highway (seasonal)</li>
                        <li><strong>Badlands National Park</strong> — dramatic scenery; great at sunrise or sunset</li>
                        <li><strong>Wind Cave &amp; Jewel Cave</strong> — tours often sell out — book ahead</li>
                        <li><strong>Deadwood</strong> — history, dining, and entertainment</li>
                    </ul>
                </div>

                <div class="guide-subblock">
                    <h3 class="guide-subblock-title">Outdoor &amp; seasonal</h3>
                    <ul class="guide-list">
                        <li><strong>Trails:</strong> Black Hills National Forest and state park trails for all skill levels</li>
                        <li><strong>Winter:</strong> Terry Peak and other regional ski areas; dress in layers</li>
                        <li><strong>Stargazing:</strong> Dark skies at the retreat — minimal porch light after quiet hours</li>
                    </ul>
                </div>
            </div>
        </article>

        <article id="resources" class="guide-card guide-card--resources">
            <header class="guide-card-header">
                <span class="guide-card-icon" aria-hidden="true">📋</span>
                <div>
                    <h2 class="guide-card-title">Helpful resources</h2>
                    <p class="guide-card-subtitle">Weather, emergencies, and getting help</p>
                </div>
            </header>
            <div class="guide-card-body">
                <ul class="guide-list">
                    <li><strong>Property address &amp; directions:</strong> In your booking confirmation and platform messages</li>
                    <li><strong>Weather:</strong> <a class="guide-link" href="/weather">Local forecast on our site</a> — mountain weather changes fast</li>
                    <li><strong>Emergency:</strong> Call <strong>911</strong> for police, fire, or ambulance</li>
                    <li><strong>Non-emergency help:</strong> Message us through your booking platform or <a class="guide-link" href="/contact">contact form</a></li>
                    <li><strong>Nearest hospital (Rapid City):</strong> Monument Health Rapid City Hospital — use maps for current address and ER entrance</li>
                    <li><strong>Pharmacy &amp; urgent care:</strong> Several options in Rapid City; search “urgent care Rapid City SD”</li>
                    <li><strong>Propane / grill fuel:</strong> Local hardware and grocery stores in Rapid if you need refills</li>
                </ul>
                <p class="guide-disclaimer">
                    This guide is general information for guests. Your booking confirmation and house rules from
                    Airbnb, Vrbo, or Nestled Nooks always apply for your specific reservation.
                </p>
            </div>
        </article>

        <footer class="guide-footer">
            <a class="guide-footer-btn guide-footer-btn--secondary" href="/properties/deerfield-retreat">← Deerfield Retreat</a>
            <a class="guide-footer-btn guide-footer-btn--primary" href="/booking?property=deerfield-retreat">Request a booking</a>
        </footer>
    </main>
</div>
