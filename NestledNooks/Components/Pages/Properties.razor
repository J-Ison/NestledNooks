@page "/properties"

<PageTitle>@SiteBranding.PageTitle("Our properties")</PageTitle>
<HeadContent>
    <meta name="description" content="Browse Nestled Nooks getaways. Deerfield Retreat — a peaceful stay near Rapid City, South Dakota, with prairie views and room for the whole group." />
</HeadContent>

<div class="guide-page">
    <header class="guide-hero">
        <div class="wrap guide-hero-inner">
            <p class="guide-hero-eyebrow">@SiteBranding.Name · @SiteBranding.RegionLine</p>
            <h1 class="guide-hero-title">Our properties</h1>
            <p class="guide-hero-lead">
                Peaceful Black Hills stays with room to spread out. Each Nestled Nooks property is set up for families, groups, and slow-down weekends.
            </p>
        </div>
    </header>

    <main class="wrap guide-main">
        <div class="properties-grid">
            <article class="property-card">
                <h2 class="property-card-title">Deerfield Retreat</h2>
                <p class="property-card-desc">
                    A peaceful getaway surrounded by open fields and visiting deer near Rapid City.
                    Sleeps up to 12 · 4 bedrooms · 3 baths · prairie views.
                </p>
                <a href="/properties/deerfield-retreat" class="guide-footer-btn guide-footer-btn--primary">View property</a>
            </article>
        </div>

        <footer class="guide-footer">
            <a class="guide-footer-btn guide-footer-btn--secondary" href="/">← Deerfield Retreat</a>
            <a class="guide-footer-btn guide-footer-btn--primary" href="/booking?property=deerfield-retreat">Request booking</a>
        </footer>
    </main>
</div>
