@page "/"
@page "/properties/{Slug}"
@rendermode InteractiveServer
@using NestledNooks.Data
@using NestledNooks.Services
@inject NavigationManager Nav
@inject IPropertyService PropertyService

@if (_loading)
{
    <div class="listing-page">
        <main class="wrap">
            <p class="nn-loading">Loading…</p>
        </main>
    </div>
}
else if (_property is null)
{
    <div class="listing-page">
        <main class="wrap">
            <p class="nn-note nn-note--error">Property not found.</p>
            <a class="guide-link" href="/properties">Browse properties</a>
        </main>
    </div>
}
else
{
    var photos = _photos;
    var sidePhotos = photos.Skip(1).Take(4);
    var lastWidePhoto = photos.Skip(5).FirstOrDefault();
    var hasLastWidePhoto = lastWidePhoto is not null;

    <PageTitle>@_property.DisplayName · @SiteBranding.Name</PageTitle>
    <HeadContent>
        <meta name="description" content="@_property.MetaDescription" />
    </HeadContent>

    <div class="listing-page">
        <main class="wrap">
            <header class="listing-header">
                <p class="listing-eyebrow">@SiteBranding.RegionLine</p>
                <h1 class="title">@_property.DisplayName</h1>
                <p class="subtitle">@_property.Subtitle</p>
                @if (_stats.Count > 0)
                {
                    <ul class="listing-stats" aria-label="Property highlights">
                        @foreach (var stat in _stats)
                        {
                            <li>@stat</li>
                        }
                    </ul>
                }
            </header>

            @if (photos.Count > 0)
            {
                <section class="media-grid" aria-label="Listing photos">
                    <div class="media-main">
                        <img src="@photos[0].Url" alt="@photos[0].Alt" loading="lazy" />
                    </div>

                    <div class="media-side @(hasLastWidePhoto ? "has-wide" : "no-wide")">
                        @foreach (var p in sidePhotos)
                        {
                            <img src="@p.Url" alt="@p.Alt" loading="lazy" />
                        }

                        @if (hasLastWidePhoto)
                        {
                            <div class="media-last">
                                <img src="@lastWidePhoto!.Url" alt="@lastWidePhoto!.Alt" loading="lazy" />
                                <button type="button"
                                        class="show-photos"
                                        @onclick="OpenGallery"
                                        @onclick:stopPropagation="true">
                                    Show all photos
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="media-last no-photo">
                                <button type="button"
                                        class="show-photos"
                                        @onclick="OpenGallery"
                                        @onclick:stopPropagation="true">
                                    Show all photos
                                </button>
                            </div>
                        }
                    </div>
                </section>
            }

            <section class="content-grid">
                <div class="left">
                    <div class="listing-intro-card">
                        <div class="subhead">
                            @if (!string.IsNullOrWhiteSpace(_property.TagsLine1))
                            {
                                <div class="line-1">@_property.TagsLine1</div>
                            }
                            @if (!string.IsNullOrWhiteSpace(_property.TagsLine2))
                            {
                                <div class="line-2">@_property.TagsLine2</div>
                            }
                        </div>

                        @if (_badges.Count > 0)
                        {
                            <div class="badges">
                                @foreach (var badge in _badges)
                                {
                                    <div class="badge">
                                        <div class="badge-title">@badge.Title</div>
                                        <div class="badge-sub">@badge.Subtitle</div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_property.AboutText))
                    {
                        <article class="listing-block">
                            <h2 class="listing-block-title">About this property</h2>
                            <p class="desc">@_property.AboutText</p>
                        </article>
                    }

                    @if (_amenities.Count > 0)
                    {
                        <article class="listing-block">
                            <h2 class="listing-block-title">Amenities</h2>
                            <ul class="listing-amenities">
                                @foreach (var amenity in _amenities)
                                {
                                    <li>@amenity</li>
                                }
                            </ul>
                        </article>
                    }

                    @if (!string.IsNullOrWhiteSpace(_property.LocationText))
                    {
                        <article class="listing-block">
                            <h2 class="listing-block-title">Location</h2>
                            <p class="desc">@_property.LocationText</p>
                        </article>
                    }

                    <article class="listing-block listing-block--guide">
                        <div class="listing-guide-inner">
                            <div>
                                <h2 class="listing-block-title">Guest guide</h2>
                                <p class="desc">@_property.GuideTeaserText</p>
                            </div>
                            <a class="listing-guide-btn" href="/properties/@_property.Slug/guide">Open guest guide</a>
                        </div>
                    </article>
                </div>

                <aside class="right">
                    <div class="booking-card">
                        <div class="booking-head">
                            <div class="booking-title">Book your stay</div>
                            <div class="booking-sub">@_property.BookingSubtext</div>
                        </div>

                        <div class="cta-stack">
                            <a class="primary-btn site-book"
                               href="/booking?property=@_property.Slug">
                                Request booking
                            </a>

                            @if (!string.IsNullOrWhiteSpace(_property.AirbnbUrl))
                            {
                                <a class="primary-btn airbnb"
                                   href="@_property.AirbnbUrl"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    View on Airbnb
                                </a>
                            }

                            @if (!string.IsNullOrWhiteSpace(_property.VrboUrl))
                            {
                                <a class="primary-btn vrbo"
                                   href="@_property.VrboUrl"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    View on Vrbo
                                </a>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_property.BookingFinePrint))
                        {
                            <div class="fineprint">@_property.BookingFinePrint</div>
                        }
                    </div>
                </aside>
            </section>
        </main>

        @if (IsGalleryOpen && photos.Count > 0)
        {
            <div class="gallery-overlay" @onclick="CloseGallery">
                <div class="gallery-modal" @onclick:stopPropagation>
                    <div class="gallery-header">
                        <button class="gallery-close" type="button" @onclick="CloseGallery">✕</button>
                        <div class="gallery-count">@($"{SelectedIndex + 1} / {photos.Count}")</div>
                    </div>

                    <div class="gallery-body">
                        <button class="gallery-nav prev" type="button" @onclick="Prev" disabled="@(!CanPrev)">‹</button>

                        <div class="gallery-main">
                            <img src="@photos[SelectedIndex].Url" alt="@photos[SelectedIndex].Alt" />
                            <div class="gallery-caption">@photos[SelectedIndex].Alt</div>
                        </div>

                        <button class="gallery-nav next" type="button" @onclick="Next" disabled="@(!CanNext)">›</button>
                    </div>

                    <div class="gallery-thumbs">
                        @for (var i = 0; i < photos.Count; i++)
                        {
                            var p = photos[i];
                            var thumbIndex = i;
                            <button class="thumb @(i == SelectedIndex ? "active" : "")"
                                    type="button"
                                    @onclick="(() => Select(thumbIndex))">
                                <img src="@p.Url" alt="@p.Alt" loading="lazy" />
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public string? Slug { get; set; }

    private RentalProperty? _property;
    private IReadOnlyList<PropertyPhoto> _photos = [];
    private IReadOnlyList<string> _stats = [];
    private IReadOnlyList<PropertyBadge> _badges = [];
    private IReadOnlyList<string> _amenities = [];
    private bool _loading = true;

    private bool IsGalleryOpen { get; set; }
    private int SelectedIndex { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;

        _property = string.IsNullOrWhiteSpace(Slug)
            ? await PropertyService.GetHomepageAsync()
            : await PropertyService.GetBySlugAsync(Slug);

        if (_property is not null)
        {
            _photos = PropertyContentJson.ParsePhotos(_property.PhotosJson);
            _stats = PropertyContentJson.ParseStringList(_property.StatsJson);
            _badges = PropertyContentJson.ParseBadges(_property.BadgesJson);
            _amenities = PropertyContentJson.ParseStringList(_property.AmenitiesJson);
        }

        _loading = false;
    }

    private bool CanPrev => SelectedIndex > 0;
    private bool CanNext => SelectedIndex < _photos.Count - 1;

    private void OpenGallery()
    {
        SelectedIndex = 0;
        IsGalleryOpen = true;
    }

    private void CloseGallery() => IsGalleryOpen = false;

    private void Prev()
    {
        if (CanPrev) SelectedIndex--;
    }

    private void Next()
    {
        if (CanNext) SelectedIndex++;
    }

    private void Select(int index)
    {
        if (index >= 0 && index < _photos.Count) SelectedIndex = index;
    }
}
