@using NestledNooks.Services
@inject ISiteThemeService SiteThemeService

@((MarkupString)_styleTag)

@code {
    private string _styleTag = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var css = await SiteThemeService.GetEffectiveCssAsync();
            _styleTag = $"<style id=\"nn-site-theme\">{css}</style>";
        }
        catch
        {
            var fallback = SiteThemeCss.BuildStyleBlock(SiteThemePresets.CreateTheme(SiteThemePresets.Default));
            _styleTag = $"<style id=\"nn-site-theme\">{fallback}</style>";
        }
    }
}
