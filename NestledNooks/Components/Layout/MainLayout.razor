@inherits LayoutComponentBase
@using MudBlazor
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using NestledNooks.Data
@using NestledNooks.Services
@using Microsoft.Extensions.DependencyInjection

@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@inject IServiceScopeFactory ScopeFactory
@inject AdminNotificationStateNotifier NotificationNotifier

@implements IDisposable

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="4" Dense="true" Class="nn-appbar nn-appbar-sky">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="ToggleDrawer" />

        <a href="/" class="nn-brand nn-brand-inline nn-brand-link" @onclick="CloseDrawerLocal">
            <img src="/images/apple5_blue.png" alt="Logo" class="nn-logo-img" />
            <div class="nn-brand-text">
                <div class="nn-brand-title">@SiteBranding.Name</div>
                <div class="nn-brand-subtitle">@SiteBranding.Tagline</div>
            </div>
        </a>

        <MudSpacer />
    </MudAppBar>

    <ThemePreviewBanner />

    <MudDrawer Open="@_drawerOpen"
               OpenChanged="OnDrawerOpenChanged"
               Variant="DrawerVariant.Temporary"
               Anchor="Anchor.Left"
               Elevation="0"
               Overlay="true"
               ClipMode="DrawerClipMode.Never"
               Width="300px"
               Class="nn-drawer">

        <div class="nn-drawer-shell">
            <header class="nn-drawer-hero">
                <div class="nn-drawer-brand">
                    <img src="/images/apple5_blue.png" alt="" class="nn-drawer-logo" />
                    <div class="nn-drawer-brand-text">
                        <span class="nn-drawer-brand-title">@SiteBranding.Name</span>
                        <span class="nn-drawer-brand-tag">@SiteBranding.Tagline</span>
                    </div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Class="nn-drawer-close"
                               OnClick="@CloseDrawerLocal"
                               aria-label="Close menu" />
            </header>

            <div class="nn-drawer-scroll">
                <MudNavMenu Class="nn-drawer-menu">
                    <div class="nn-drawer-section-label">Explore</div>

                    <MudNavLink Href="/"
                                Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Home"
                                OnClick="@CloseDrawerLocal">
                        Deerfield Retreat
                    </MudNavLink>

                    <MudNavLink Href="/booking?property=deerfield-retreat"
                                Icon="@Icons.Material.Filled.EventAvailable"
                                OnClick="@CloseDrawerLocal">
                        Request booking
                    </MudNavLink>

                    <MudNavLink Href="/properties/deerfield-retreat/guide"
                                Icon="@Icons.Material.Filled.MenuBook"
                                OnClick="@CloseDrawerLocal">
                        Guest guide
                    </MudNavLink>

                    <MudNavLink Href="/contact"
                                Icon="@Icons.Material.Filled.Email"
                                OnClick="@CloseDrawerLocal">
                        Contact
                    </MudNavLink>

                    <AuthorizeView>
                        <NotAuthorized>
                            <div class="nn-drawer-section-label">Account</div>

                            <MudNavLink Href="/login"
                                        Icon="@Icons.Material.Filled.Lock"
                                        OnClick="@CloseDrawerLocal">
                                Login
                            </MudNavLink>

                            <MudNavLink Href="/register"
                                        Icon="@Icons.Material.Filled.PersonAdd"
                                        OnClick="@CloseDrawerLocal">
                                Register
                            </MudNavLink>
                        </NotAuthorized>
                    </AuthorizeView>

                    <AuthorizeView>
                        <Authorized>
                            <div class="nn-drawer-section-label">Your account</div>

                            <MudNavLink Href="/account/messages"
                                        Icon="@Icons.Material.Filled.Mail"
                                        OnClick="@CloseDrawerLocal">
                                <span class="nn-nav-label">
                                    Messages
                                    @if (_summary?.UnreadMessages is > 0)
                                    {
                                        <span class="nn-nav-badge" aria-label="@($"{_summary.UnreadMessages} unread")">@FormatBadgeCount(_summary.UnreadMessages)</span>
                                    }
                                </span>
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/settings"
                                        Icon="@Icons.Material.Filled.Settings"
                                        OnClick="@CloseDrawerLocal">
                                Settings
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Roles="@AppRoles.HostStaff">
                        <Authorized>
                            <div class="nn-drawer-section-label">Host tools</div>

                            <MudNavLink Href="/account/manage/bookings"
                                        Icon="@Icons.Material.Filled.CalendarMonth"
                                        OnClick="@CloseDrawerLocal">
                                <span class="nn-nav-label">
                                    Manage bookings
                                    @if (_summary?.UnseenBookings is > 0)
                                    {
                                        <span class="nn-nav-badge" aria-label="@($"{_summary.UnseenBookings} unseen updates")">@FormatBadgeCount(_summary.UnseenBookings)</span>
                                    }
                                </span>
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/properties"
                                        Icon="@Icons.Material.Filled.House"
                                        OnClick="@CloseDrawerLocal">
                                Property contacts &amp; ops
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/guest-messages"
                                        Icon="@Icons.Material.Filled.Quickreply"
                                        OnClick="@CloseDrawerLocal">
                                Guest message templates
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>

                    <AuthorizeView Roles="@AppRoles.Owner">
                        <Authorized>
                            <div class="nn-drawer-section-label">Owner tools</div>

                            <MudNavLink Href="/account/manage/site"
                                        Icon="@Icons.Material.Filled.Palette"
                                        OnClick="@CloseDrawerLocal">
                                Manage site
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/properties"
                                        Icon="@Icons.Material.Filled.House"
                                        OnClick="@CloseDrawerLocal">
                                Manage properties
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/users"
                                        Icon="@Icons.Material.Filled.People"
                                        OnClick="@CloseDrawerLocal">
                                <span class="nn-nav-label">
                                    Manage users
                                    @if (_summary?.NewUsers is > 0)
                                    {
                                        <span class="nn-nav-badge" aria-label="@($"{_summary.NewUsers} new users")">@FormatBadgeCount(_summary.NewUsers)</span>
                                    }
                                </span>
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/contact"
                                        Icon="@Icons.Material.Filled.ContactMail"
                                        OnClick="@CloseDrawerLocal">
                                <span class="nn-nav-label">
                                    Contact inquiries
                                    @if (_summary?.NewContactInquiries is > 0)
                                    {
                                        <span class="nn-nav-badge" aria-label="@($"{_summary.NewContactInquiries} new inquiries")">@FormatBadgeCount(_summary.NewContactInquiries)</span>
                                    }
                                </span>
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/qr-codes"
                                        Icon="@Icons.Material.Filled.QrCode2"
                                        OnClick="@CloseDrawerLocal">
                                QR codes
                            </MudNavLink>

                            <MudNavLink Href="/account/manage/payments"
                                        Icon="@Icons.Material.Filled.Payments"
                                        OnClick="@CloseDrawerLocal">
                                Payment settings
                            </MudNavLink>
                        </Authorized>
                    </AuthorizeView>
                </MudNavMenu>
            </div>

            <footer class="nn-drawer-footer">
                <AuthorizeView>
                    <Authorized>
                        <div class="auth-status auth-status--signed-in">
                            <span class="status-dot green"></span>
                            <span>Signed in</span>
                        </div>

                        <form method="post" action="/api/account/logout" class="nn-drawer-logout">
                            <button type="submit" class="nn-drawer-logout-btn">Sign out</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <div class="auth-status auth-status--guest">
                            <span class="status-dot gray"></span>
                            <span>Browsing as guest</span>
                        </div>
                    </NotAuthorized>
                </AuthorizeView>
            </footer>
        </div>
    </MudDrawer>

    <MudMainContent Class="nn-main-content">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen;
    private string? _userId;
    private AdminNotificationSummary? _summary;
    private DateTime _lastNotificationRefreshUtc = DateTime.MinValue;
    private static readonly TimeSpan NotificationRefreshInterval = TimeSpan.FromMinutes(2);

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private void OnDrawerOpenChanged(bool open)
    {
        _drawerOpen = open;
        if (open)
            _ = RefreshNotificationsAsync(force: true);
    }

    private void CloseDrawerLocal() => _drawerOpen = false;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        NotificationNotifier.Changed += OnNotificationsChanged;
        await RefreshNotificationsAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs args)
    {
        InvokeAsync(async () =>
        {
            _drawerOpen = false;
            await RefreshNotificationsAsync();
            StateHasChanged();
        });
    }

    private void OnNotificationsChanged() =>
        InvokeAsync(async () =>
        {
            await RefreshNotificationsAsync();
            StateHasChanged();
        });

    private async Task RefreshNotificationsAsync(bool force = false)
    {
        if (!force && DateTime.UtcNow - _lastNotificationRefreshUtc < NotificationRefreshInterval)
            return;

        var auth = await AuthState.GetAuthenticationStateAsync();
        if (auth.User.Identity?.IsAuthenticated != true)
        {
            _userId = null;
            _summary = null;
            return;
        }

        _userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        if (string.IsNullOrEmpty(_userId))
        {
            _summary = null;
            return;
        }

        await using var scope = ScopeFactory.CreateAsyncScope();
        var adminNotifications = scope.ServiceProvider.GetRequiredService<IAdminNotificationService>();
        _summary = await adminNotifications.GetSummaryAsync(_userId);
        _lastNotificationRefreshUtc = DateTime.UtcNow;
    }

    private static string FormatBadgeCount(int count) => count > 9 ? "9+" : count.ToString();

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        NotificationNotifier.Changed -= OnNotificationsChanged;
    }
}
