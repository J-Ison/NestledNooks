@page "/account/manage/bookings"
@layout NestledNooks.Components.Layout.MainLayout
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using MudBlazor
@using NestledNooks.Data
@using NestledNooks.Models
@using NestledNooks.Services

@attribute [Authorize(Roles = "Owner,Manager")]

@inject IBookingRequestService BookingService
@inject NavigationManager Navigation

<PageTitle>Manage bookings</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">
    <MudText Typo="Typo.h4" Class="mb-2">Manage bookings</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
        Approve or deny pending requests. Approved and pending dates are blocked on the site.
        Import <MudLink Href="@_holdsFeedUrl" Target="_blank">holds.ics</MudLink> into Airbnb/Vrbo to block pending site requests on those platforms.
    </MudText>

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" />
    }
    else if (_pending.Count == 0)
    {
        <MudAlert Severity="Severity.Info">No pending booking requests.</MudAlert>
    }
    else
    {
        @foreach (var b in _pending)
        {
            <MudCard Class="mb-4">
                <MudCardContent>
                    <MudText Typo="Typo.h6">@b.BookingNumber — @b.PropertySlug</MudText>
                    <MudText Typo="Typo.body2">
                        @b.GuestFullName · @b.GuestEmail · @b.GuestPhone
                    </MudText>
                    <MudText Typo="Typo.body2">
                        @b.CheckIn:yyyy-MM-dd → @b.CheckOut:yyyy-MM-dd · @b.NightCount night(s) · @b.GuestCount guests · @b.PetCount pets
                    </MudText>
                    <MudText Typo="Typo.body1" Class="my-2">
                        <strong>@b.TotalAmount.ToString("C2")</strong>
                        · Payment: @b.PaymentStatus
                        @if (b.AmountPaid > 0)
                        {
                            <span> (paid @b.AmountPaid.ToString("C2"))</span>
                        }
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(b.Notes))
                    {
                        <MudText Typo="Typo.body2" Class="mb-2">Notes: @b.Notes</MudText>
                    }

                    <MudTextField @bind-Value="_statusNotes[b.Id]"
                                  Label="Message to guest (optional)"
                                  Variant="Variant.Outlined"
                                  Class="mb-3" />

                    <MudStack Row="true" Spacing="2">
                        <MudButton Color="Color.Success"
                                   Variant="Variant.Filled"
                                   Disabled="_processingId == b.Id"
                                   OnClick="() => UpdateStatusAsync(b.Id, BookingStatuses.Approved)">
                            Approve
                        </MudButton>
                        <MudButton Color="Color.Error"
                                   Variant="Variant.Outlined"
                                   Disabled="_processingId == b.Id"
                                   OnClick="() => UpdateStatusAsync(b.Id, BookingStatuses.Denied)">
                            Deny
                        </MudButton>
                    </MudStack>

                    @if (_errors.TryGetValue(b.Id, out var err))
                    {
                        <MudText Color="Color.Error" Class="mt-2">@err</MudText>
                    }
                </MudCardContent>
            </MudCard>
        }
    }
</MudContainer>

@code {
    private List<BookingRequest> _pending = [];
    private readonly Dictionary<int, string> _statusNotes = new();
    private readonly Dictionary<int, string> _errors = new();
    private bool _loading = true;
    private int? _processingId;
    private string _holdsFeedUrl = "";

    protected override async Task OnInitializedAsync()
    {
        _holdsFeedUrl = Navigation.ToAbsoluteUri($"/api/calendar/{BookingFormModel.DeerfieldSlug}/holds.ics").ToString();
        _pending = (await BookingService.GetPendingForPropertyAsync()).ToList();
        foreach (var b in _pending)
            _statusNotes[b.Id] = "";
        _loading = false;
    }

    private async Task UpdateStatusAsync(int id, string status)
    {
        _processingId = id;
        _errors.Remove(id);
        StateHasChanged();

        var note = _statusNotes.TryGetValue(id, out var n) ? n : null;
        var result = await BookingService.UpdateStatusAsync(id, status, note);

        if (!result.Succeeded)
        {
            _errors[id] = result.ErrorMessage ?? "Update failed.";
            _processingId = null;
            return;
        }

        _pending.RemoveAll(b => b.Id == id);
        _processingId = null;
    }
}
